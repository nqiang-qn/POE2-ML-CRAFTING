{
	"name": "poe2-ml-crafting",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "tsc -b",
		"typecheck": "tsc -b --pretty false",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "npm run docs:check && npm run typecheck && npm run lint && npm run format:check && npm test && npm run test:python",
		"docs:check": "node scripts/check-documentation.mjs",
		"test": "tsx tests/import-poe2db-modifiers.test.ts && tsx tests/market-prices.test.ts && tsx tests/crafting-actions.test.ts",
		"import:gloves": "tsx packages/poe2db-importer/src/cli.ts",
		"import:essences": "tsx packages/poe2db-importer/src/essence-cli.ts",
		"query:modifiers": "tsx packages/data/src/query-cli.ts",
		"import:prices": "tsx packages/data/src/market-price-cli.ts",
		"simulate": "tsx packages/simulator/src/simulate-cli.ts",
		"sample:transition": "tsx packages/simulator/src/transition-cli.ts",
		"discover:graph": "tsx packages/simulator/src/graph-cli.ts",
		"fixture:e2e-graph": "tsx tests/export-e2e-graph.ts",
		"test:python": "python -m unittest discover -s experiments -p \"test_*.py\"",
		"validate:essences": "tsx packages/simulator/src/validate-essences-cli.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^24.13.3",
		"eslint": "^10.7.0",
		"prettier": "^3.9.5",
		"tsx": "^4.20.0",
		"typescript": "^5.9.0",
		"typescript-eslint": "^8.63.0"
	}
}
